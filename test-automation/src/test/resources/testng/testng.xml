<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Insider Suite (default)" verbose="2" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="org.insider.listeners.AllureFailureListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="All Tests">
        <classes>
            <class name="org.insider.homepage.HomePageTests"/>
            <class name="org.insider.careers.CareersPageTests"/>
        </classes>
    </test>

</suite>
