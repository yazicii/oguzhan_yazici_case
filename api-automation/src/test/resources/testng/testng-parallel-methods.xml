<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Parallel: each @Test method runs in its own thread. -->
<suite name="Pet API Suite (parallel methods)" verbose="2" parallel="methods" thread-count="4">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="All Pet API Tests">
        <classes>
            <class name="org.insider.pet.CreatePetTests"/>
            <class name="org.insider.pet.ReadPetTests"/>
            <class name="org.insider.pet.UpdatePetTests"/>
            <class name="org.insider.pet.DeletePetTests"/>
        </classes>
    </test>

</suite>
